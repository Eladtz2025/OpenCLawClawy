{
  "system_name": "PC Guardian",
  "version": "1.2.0",
  "runtime": "node",
  "entrypoint": "scripts/run-checks.js",
  "dashboard": "dashboard/index.html",
  "state": "state/state.json",
  "logs": "logs",
  "mode": "reporting-only",
  "config": [
    "config/config.json",
    "config/rules.json",
    "config/secrets.example.json"
  ],
  "schedule": {
    "type": "windows-task-scheduler",
    "wrapper": "scripts/run-pc-guardian.ps1",
    "default_interval_minutes": 120
  },
  "capabilities": [
    "dashboard",
    "checks",
    "alerts",
    "reporting-only"
  ]
}
