{
  "system_name": "PC Guardian",
  "version": "1.1.0",
  "monitoring": {
    "interval_minutes": 15,
    "connectivity_targets": [
      "1.1.1.1",
      "8.8.8.8"
    ],
    "internet_targets": [
      "https://www.msftconnecttest.com/connecttest.txt",
      "https://www.google.com/generate_204"
    ],
    "gateway_health_timeout_ms": 5000,
    "recent_event_hours": 6,
    "max_recent_failures": 3,
    "max_dashboard_failures": 20,
    "max_log_lines": 400,
    "growth_scan_roots": [
      "C:\\Users\\Itzhak\\.openclaw\\workspace",
      "C:\\Users\\Itzhak\\.openclaw"
    ],
    "growth_scan_patterns": [
      "sessions",
      "logs",
      "backups"
    ]
  },
  "thresholds": {
    "cpu_warning": 80,
    "cpu_critical": 95,
    "ram_warning": 80,
    "ram_critical": 95,
    "disk_warning_free_gb": 20,
    "disk_critical_free_gb": 5,
    "disk_activity_warning_pct": 80,
    "disk_activity_critical_pct": 95,
    "event_error_warning": 3,
    "event_error_critical": 10,
    "failure_repeat_warning": 2,
    "failure_repeat_critical": 4,
    "growth_warning_mb": 1024,
    "growth_critical_mb": 4096,
    "runaway_backup_minutes": 90,
    "max_log_size_mb": 5,
    "max_log_files": 6,
    "old_temp_days": 7,
    "old_log_days": 14
  },
  "openclaw": {
    "gateways": [
      {
        "name": "gateway-18789",
        "url": "http://127.0.0.1:18789/health"
      },
      {
        "name": "gateway-18790",
        "url": "http://127.0.0.1:18790/health"
      }
    ],
    "scheduled_task_patterns": [
      "OpenClaw"
    ],
    "important_services": [
      "OpenClawGateway"
    ],
    "safe_fallback_models": [
      "gpt-4o-mini",
      "openai-codex/gpt-5.4"
    ]
  },
  "alerts": {
    "channel": "telegram",
    "cooldown_minutes": 20,
    "normal_template": "PC Guardian: תקין.",
    "warning_template": "PC Guardian Warning: {summary}",
    "critical_template": "PC Guardian Critical: {summary}",
    "telegram": {
      "bot_token": "",
      "chat_id": "",
      "silent": false
    }
  },
  "dashboard_publish": {
    "enabled": false,
    "mode": "copy",
    "target_dir": "",
    "repo_dir": "",
    "remote": "origin",
    "branch": "main",
    "html_file_name": "index.html",
    "data_file_name": "data.json",
    "commit_message": "Update PC Guardian dashboard"
  },
  "paths": {
    "state_file": "state/state.json",
    "dashboard_data_file": "dashboard/data.json",
    "dashboard_file": "dashboard/index.html",
    "log_dir": "logs"
  }
}